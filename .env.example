# Google Apps Script Web App URL (Sheet export, requirements §13)
GOOGLE_SHEET_WEB_APP_URL=

# LLM — OpenAI-compatible endpoint (e.g. self-hosted vLLM).
# Used for AI keyword-gen (§7) and lead scoring/enrichment (§9).
LLM_HOST=https://your-gateway/v1
LLM_MODEL=vllm/qwen3.5-35b
LLM_API_KEY=sk-...

